# Supabase - https://supabase.com 에서 프로젝트 생성 후 복사
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 카카오 알림톡 - 카카오 비즈니스 채널 개설 후 입력
VITE_KAKAO_API_KEY=your_kakao_api_key

# Server secrets - set these only in Vercel/Supabase dashboards, not in client code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Firebase Cloud Messaging
FIREBASE_WEB_CONFIG_JSON={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
FIREBASE_VAPID_KEY=your_firebase_web_push_vapid_public_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
WEB_PUSH_PUBLIC_KEY=your_vapid_public_key_for_native_web_push_fallback
WEB_PUSH_PRIVATE_KEY=your_vapid_private_key_for_native_web_push_fallback
WEB_PUSH_SUBJECT=mailto:nunuanu866@gmail.com
PUSH_DISPATCH_SECRET=optional_dispatch_secret
NUNUANU_APP_URL=https://nununanu-app.vercel.app
