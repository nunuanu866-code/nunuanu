{
  "version": 2,
  "rewrites": [
    {
      "source": "/booking",
      "destination": "/index.html"
    },
    {
      "source": "/my",
      "destination": "/index.html"
    },
    {
      "source": "/admin-login",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0, s-maxage=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
